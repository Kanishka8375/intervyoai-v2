{
  "name": "intervyoai",
  "version": "1.0.0",
  "description": "AI Interview Copilot - 100% Local, 100% Undetectable",
  "homepage": "https://github.com/intervyoai/intervyoai",
  "main": "electron/main.js",
  "author": {
    "name": "IntervyoAI Team",
    "email": "team@intervyoai.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win:nsis": "electron-builder --win nsis",
    "build:win:msi": "electron-builder --win msi",
    "build:mac": "electron-builder --mac",
    "build:mac:dmg": "electron-builder --mac dmg",
    "build:mac:zip": "electron-builder --mac zip",
    "build:linux": "electron-builder --linux",
    "build:linux:deb": "electron-builder --linux deb",
    "build:linux:rpm": "electron-builder --linux rpm",
    "build:linux:appimage": "electron-builder --linux AppImage",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.intervyoai.app",
    "productName": "IntervyoAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "electron/**/*",
      "frontend/**/*",
      "models/**/*",
      "config/**/*"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models"
      },
      {
        "from": "config",
        "to": "config"
      },
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "frontend",
        "to": "frontend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "msi",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IntervyoAI"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "maintainer": "IntervyoAI Team <team@intervyoai.com>"
    },
    "asar": true,
    "asarUnpack": [
      "models/**/*"
    ]
  },
  "dependencies": {
    "electron-log": "^5.1.1",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
